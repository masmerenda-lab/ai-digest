# --- Google Gemini ---
GEMINI_API_KEY=la-tua-chiave-gemini

# --- GitHub Pages ---
# URL base del sito pubblicato su GitHub Pages (senza slash finale)
# es. https://massimo.github.io/ai-digest
GITHUB_PAGES_BASE_URL=https://TUO_UTENTE.github.io/NOME_REPO

# --- Cloudflare Worker ---
# URL del Worker deployato su Cloudflare
WORKER_URL=https://ai-digest-notify.TUO_UTENTE.workers.dev

# Segreto condiviso tra digest.py e il Worker (stringa casuale lunga)
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
NOTIFY_SECRET=cambia-con-una-stringa-casuale-sicura

# --- VAPID keys (Web Push) ---
# Genera con: npx web-push generate-vapid-keys
# oppure:     python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); print('PUB:', v.public_key_b64()); print('PRI:', v.private_key_b64())"
#
# VAPID_PUBLIC_KEY va anche copiata in web/app.js (riga VAPID_PUBLIC_KEY=)
# VAPID_PRIVATE_KEY va settata come secret nel Worker:
#   wrangler secret put VAPID_PRIVATE_KEY
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
